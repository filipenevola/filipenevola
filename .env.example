# MongoDB (database: verdaoracional)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# API de posts — mínimo 32 caracteres; configure como SECRET no Quave One (runtime)
POSTS_API_SECRET=generate-a-random-secret-at-least-32-chars-long

# URL pública do site (Open Graph e metadata)
NEXT_PUBLIC_SITE_URL=https://verdaoracional.com

# Google Calendar — embed ou link público da agenda de jogos
NEXT_PUBLIC_GOOGLE_CALENDAR_URL=https://calendar.google.com/calendar/embed?src=SEU_CALENDARIO&ctz=America%2FSao_Paulo
